# ============================================================
# Environment variables — copy to .env and fill in values
# cp .env.example .env
# ============================================================

# ── PostgreSQL ─────────────────────────────────────────────
POSTGRES_USER=admin
POSTGRES_PASSWORD=changeme_postgres_password
N8N_DB_NAME=n8n
API_DB_NAME=appdb

# ── Redis ──────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0        # DB 0 = Celery broker + backend
                                      # DB 1 = n8n queue (géré automatiquement)

# ── n8n ────────────────────────────────────────────────────
N8N_HOST=n8n.yourdomain.com
N8N_PROTOCOL=https
N8N_WEBHOOK_URL=https://n8n.yourdomain.com/
N8N_EDITOR_BASE_URL=https://n8n.yourdomain.com/
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=changeme_n8n_password
N8N_ENCRYPTION_KEY=changeme_32char_encryption_key_here
N8N_EXECUTIONS_MODE=queue             # queue = Redis (recommandé en prod)

# ── FastAPI ────────────────────────────────────────────────
API_SECRET_KEY=changeme_api_secret_key_64chars_minimum
API_ENV=production                    # development | production
ALLOWED_ORIGINS=https://n8n.yourdomain.com,https://app.yourdomain.com
INTERNAL_API_KEY=changeme_internal_api_key_32chars   # clé X-API-Key n8n→FastAPI

# ── Celery ─────────────────────────────────────────────────
CELERY_CONCURRENCY=4                  # workers parallèles par container

# ── FastAPI uvicorn ─────────────────────────────────────────
WEB_CONCURRENCY=4                     # workers uvicorn (recommandé: nb_CPU * 2)

# ── Monitoring ─────────────────────────────────────────────
SENTRY_DSN=                           # laisser vide pour désactiver (obtenir sur sentry.io)
GRAFANA_PASSWORD=changeme_grafana_password

# ── Grafana Alerting ────────────────────────────────────────
# Email destinataire des alertes (séparés par des virgules)
GF_ALERT_EMAIL=alerts@ton-domaine.com
# SMTP (ex: Gmail → smtp.gmail.com:587, OVH → ssl0.ovh.net:465)
GF_SMTP_ENABLED=false
GF_SMTP_HOST=smtp.gmail.com:587
GF_SMTP_USER=                         # adresse Gmail ou autre
GF_SMTP_PASSWORD=                     # mot de passe app (pas le mot de passe Gmail)
GF_SMTP_FROM_ADDRESS=grafana@ton-domaine.com
GF_SMTP_FROM_NAME=ACWORK Grafana
# Webhook Slack/Discord (optionnel — décommenter dans contact-points.yml)
# GF_ALERT_WEBHOOK_URL=https://hooks.slack.com/services/...

# ── General ────────────────────────────────────────────────
TIMEZONE=America/Cayenne
LOG_LEVEL=info                        # debug | info | warning | error
